{
  "name": "R Development",
  "image": "ghcr.io/rocker-org/devcontainer/r-ver:4.5",
  "features": {
    "ghcr.io/rocker-org/devcontainer-features/renv-cache:0.1.2": {},
    "ghcr.io/rocker-org/devcontainer-features/quarto-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "posit.air-vscode",
        "quarto.quarto",
        "vscodevim.vim",
        "mechatroner.rainbow-csv",
        "oderwat.indent-rainbow"
      ],
      "settings": {
        "vim.enable": true,
        "editor.rulers": [78]
      }
    },
    "codespaces": {
      "openFiles": [
        "README.md",
        "R/main.R"
      ]
    }
  },
  "postCreateCommand": {
    "setup": "R -q -e \"if (!file.exists('renv.lock')) {renv::init()} else {print('renv already initialized.')}\" && R -q -e \"renv::install('languageserver', repos='https://p3m.dev/cran/__linux__/noble/latest', lock=TRUE, prompt=FALSE, dependencies=TRUE)\""
  },
  "postStartCommand": {
    "renv-restore": [
      "R",
      "-q",
      "-e",
      "renv::restore()"
    ]
  }
}
